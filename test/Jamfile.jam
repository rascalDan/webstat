lib benchmark : : <link>shared ;
lib boost_unit_test_framework : : <link>shared ;
lib dbpptestcore : : <link>shared ;
lib stdc++fs ;

path-constant src : ../src ;
path-constant test : . ;
path-constant fixtures : fixtures ;

project WebStat-Testing : requirements
	<define>SRC=\"$(src)\"
	<define>TEST=\"$(test)\"
	<define>FIXTURES=\"$(fixtures)\"
	<library>$(src)//webstat
	<toolset>gcc,<variant>debug:<cflags>-Wno-missing-field-initializers
	;

lib test-util :
	test-util.cpp
	:
	<library>..//dbpp-postgresql
	;

run test-ingest.cpp :
	-- :
	../src/schema.sql
	:
	<define>BOOST_TEST_DYN_LINK
	<library>test-util
	<library>..//dbpp-postgresql
	<library>boost_unit_test_framework
	<library>dbpptestcore
	<library>stdc++fs
	;

exe perf-ingest : perf-ingest.cpp :
	<library>test-util
	<library>$(src)//webstat
	<library>..//dbpp-postgresql
	<library>benchmark
	<library>dbpptestcore
	<library>stdc++fs
	;
explicit run-perf-ingest ;
run perf-ingest : : : : run-perf-ingest ;
